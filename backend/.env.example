# HealthHub Backend – Environment Variables
# Copy this file to `.env` and fill in the values.
# DO NOT commit the real .env file to version control.

# ── Database ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=healthhub
DB_USER=root
DB_PASSWORD=your_mysql_password_here

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET_KEY=change_me_to_a_long_random_string
JWT_ACCESS_TOKEN_EXPIRES=86400        # seconds (24 h)

# ── AI Diagnosis Provider ─────────────────────────────────
# Options: rules | openai | gemini
AI_PROVIDER=openai

# OpenAI (leave empty if using rules or gemini)
OPENAI_API_KEY=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

# Google Gemini (leave empty if using rules or openai)
GEMINI_API_KEY=

# ── File Uploads ──────────────────────────────────────────
UPLOAD_DIR=uploads                    # relative to backend/

# ── SMS stub (MTN/Orange MoMo) ────────────────────────────
# Set to a real Twilio/Africa's Talking API key in production
SMS_API_KEY=
SMS_SENDER_ID=HealthHub

# ── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed origins (* for dev)
CORS_ORIGINS=*

# ── Flask ─────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=true
PORT=5000
